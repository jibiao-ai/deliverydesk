# DeliveryDesk Configuration

# AI Configuration
AI_PROVIDER=openai
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4

# JWT Secret
JWT_SECRET=deliverydesk-secret-key-change-me

# LDAP Configuration (optional, can also be configured via web UI)
LDAP_ENABLED=false
LDAP_HOST=ldap.example.com
LDAP_PORT=389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=dc=example,dc=com
